# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# Comment out during local dev — Vite proxy (vite.config.js) handles /api/* routes
# This avoids CORS issues in local development.
# VITE_API_BASE_URL=https://bkbs-backend.vercel.app

# ─── PRODUCTION ───────────────────────────────────────────────────────────────
# Uncomment the line above when deploying to production (Vercel, Netlify, etc.)
# Without this, production build won't know where the backend is.
