# ─── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# Leave VITE_API_BASE_URL unset — Vite proxies /api/* → Railway (vite.config.js).
# Restart dev server after changing this file: npm run dev

# Optional: call Railway directly (no proxy). May hit CORS unless backend allows localhost:5173.
# VITE_API_BASE_URL=https://bkbsbackend-production.up.railway.app

# Override proxy target only (rare):
# VITE_API_PROXY_TARGET=https://bkbsbackend-production.up.railway.app

# ─── PRODUCTION BUILD (non-Vercel static hosts) ───────────────────────────────
# On Vercel, vercel.json rewrites /api → Railway; base URL can stay empty.
# VITE_API_BASE_URL=https://bkbsbackend-production.up.railway.app
